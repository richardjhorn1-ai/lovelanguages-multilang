export const prerender = true;

export function getStaticPaths() {
  // Supported native languages (all 18)
  const supportedLangs = ['en', 'es', 'fr', 'de', 'it', 'pt', 'nl', 'pl', 'ru', 'uk', 'tr', 'ro', 'sv', 'no', 'da', 'cs', 'el', 'hu'];
  return supportedLangs.map(nativeLang => ({
    params: { nativeLang }
  }));
}

const { nativeLang } = Astro.params;
const lang = nativeLang || 'en';
const content = getComparisonContent(lang);

