  <!-- Header -->
  <header class="bg-gradient-to-b from-accent/10 to-white">
    <div class="max-w-4xl mx-auto px-4 py-10 md:py-14">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-black font-header text-gray-900 mb-4">
          {text.heroTitle}
        </h1>
        <p class="text-xl text-gray-600">
          {text.heroSubtitle}
        </p>
      </div>
    </div>
  </header>

  <!-- Comparisons Grid -->
  <main class="max-w-4xl mx-auto px-4 py-12">
    <div class="grid md:grid-cols-2 gap-6">
      {comparisons.map(comp => (
        <a
          href={comp.href}
          class="group bg-white rounded-2xl shadow-md hover:shadow-lg transition-all p-6 border border-gray-100 hover:border-accent/30"
        >
          <div class="flex items-center gap-4 mb-4">
            <img src="/favicon.svg" alt="Love Languages" class="w-12 h-12" />
            <span class="text-2xl text-gray-300">vs</span>
            <span class="text-4xl">{comp.competitorIcon}</span>
          </div>
          <h2 class="text-xl font-bold font-header text-gray-900 group-hover:text-accent transition-colors mb-2">
            {comp.title}
          </h2>
          <p class="text-gray-600 mb-3">{comp.description}</p>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500">
              {comp.competitor}: {comp.verdict}
            </span>
            <span class="text-accent font-medium group-hover:translate-x-1 transition-transform">
              {text.compare} →
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- Why Love Languages Section -->
    <section class="mt-12 bg-gradient-to-br from-accent/5 to-pink-50 rounded-2xl p-8">
      <h2 class="text-2xl font-bold font-header text-gray-900 mb-6 text-center">
        {text.whyChooseTitle}
      </h2>
      <div class="grid md:grid-cols-3 gap-6 mb-8">
        <div class="text-center">
          <div class="text-4xl mb-3">💕</div>
          <h3 class="font-bold text-gray-900 mb-2">{text.builtForCouples.title}</h3>
          <p class="text-gray-600 text-sm">{text.builtForCouples.description}</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-3">🎧</div>
          <h3 class="font-bold text-gray-900 mb-2">{text.listenMode.title}</h3>
          <p class="text-gray-600 text-sm">{text.listenMode.description}</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-3">🌍</div>
          <h3 class="font-bold text-gray-900 mb-2">{text.languages18.title}</h3>
          <p class="text-gray-600 text-sm">{text.languages18.description}</p>
        </div>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="text-4xl mb-3">🤖</div>
          <h3 class="font-bold text-gray-900 mb-2">{text.aiConversations.title}</h3>
          <p class="text-gray-600 text-sm">{text.aiConversations.description}</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-3">🎮</div>
          <h3 class="font-bold text-gray-900 mb-2">{text.gameModes.title}</h3>
          <p class="text-gray-600 text-sm">{text.gameModes.description}</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-3">🎁</div>
          <h3 class="font-bold text-gray-900 mb-2">{text.wordGifts.title}</h3>
          <p class="text-gray-600 text-sm">{text.wordGifts.description}</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="mt-12 bg-gradient-to-r from-accent to-pink-500 rounded-2xl p-8 text-center text-white">
      <h2 class="text-2xl md:text-3xl font-bold font-header mb-3">
        {text.ctaTitle}
      </h2>
      <p class="text-white/90 mb-6 text-lg">
        {text.ctaSubtitle}
      </p>
      <a
        href="/"
        class="inline-block bg-white text-accent font-bold px-8 py-4 rounded-full hover:shadow-lg hover:scale-105 transition-all text-lg"
      >
        {text.ctaButton} →
      </a>
    </div>
  </main>

  <!-- Footer -->
  <footer class="bg-gray-100 border-t border-gray-200 py-12">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <a href="/" class="inline-flex items-center gap-2 text-2xl font-bold font-header text-accent mb-4">
        <img src="/favicon.svg" alt="Love Languages" class="w-8 h-8" />
        Love Languages
      </a>
      <p class="text-gray-600 mb-6">{content.page.footerTagline}</p>
      <nav class="flex justify-center gap-6 text-sm text-gray-500">
        <a href={`/learn/${lang}/`} class="hover:text-accent">{content.page.blog}</a>
        <a href="/tools/" class="hover:text-accent">{content.page.tools}</a>
        <a href={`/compare/${lang}/`} class="hover:text-accent">{content.page.compare}</a>
        <a href="/terms/" class="hover:text-accent">{content.page.terms}</a>
        <a href="/privacy/" class="hover:text-accent">{content.page.privacy}</a>
      </nav>
    </div>
  </footer>
</BaseLayout>
