---
/**
 * TopicalArticlesGrid - Displays articles filtered by multiple languages and/or keywords
 * Used by Tier 2 topical hubs to show relevant articles across language families
 */
import { getArticlesByNativeLang, type BlogArticleSummary } from '../../lib/blog-api';
import { LANGUAGE_HUB_DATA } from '../../data/language-hub-data';
import { getUITranslations } from '../../data/ui-translations';

interface Props {
  // Filter by language codes (e.g., ['es', 'fr', 'it', 'pt', 'ro'] for Romance)
  langCodes?: string[];
  // Filter by keywords in title (e.g., ['love', 'romantic', 'pet name'])
  keywords?: string[];
  // Filter by category (e.g., 'phrases', 'romance', 'grammar')
  categories?: string[];
  // Maximum articles to show
  maxArticles?: number;
  // Section title
  title?: string;
  // Section subtitle
  subtitle?: string;
  // Native language to filter (default: 'en')
  nativeLang?: string;
}

// Per-component translations
const relatedArticlesLabel: Record<string, string> = {
  en: 'Related Articles', es: 'Artículos Relacionados', fr: 'Articles Connexes', de: 'Verwandte Artikel',
  it: 'Articoli Correlati', pt: 'Artigos Relacionados', pl: 'Powiązane Artykuły', nl: 'Gerelateerde Artikelen',
  ro: 'Articole Similare', ru: 'Похожие Статьи', tr: 'İlgili Makaleler', uk: 'Пов\'язані Статті',
  sv: 'Relaterade Artiklar', no: 'Relaterte Artikler', da: 'Relaterede Artikler', cs: 'Související Články',
  el: 'Σχετικά Άρθρα', hu: 'Kapcsolódó Cikkek'
};

const articlesFoundLabel: Record<string, string> = {
  en: 'articles found', es: 'artículos encontrados', fr: 'articles trouvés', de: 'Artikel gefunden',
  it: 'articoli trovati', pt: 'artigos encontrados', pl: 'znalezionych artykułów', nl: 'artikelen gevonden',
  ro: 'articole găsite', ru: 'статей найдено', tr: 'makale bulundu', uk: 'статей знайдено',
  sv: 'artiklar hittade', no: 'artikler funnet', da: 'artikler fundet', cs: 'článků nalezeno',
  el: 'άρθρα βρέθηκαν', hu: 'cikk található'
};

const minReadLabel: Record<string, string> = {
  en: 'min read', es: 'min de lectura', fr: 'min de lecture', de: 'Min. Lesezeit',
  it: 'min di lettura', pt: 'min de leitura', pl: 'min czytania', nl: 'min leestijd',
  ro: 'min de citit', ru: 'мин чтения', tr: 'dk okuma', uk: 'хв читання',
  sv: 'min läsning', no: 'min lesing', da: 'min læsning', cs: 'min čtení',
  el: 'λεπ ανάγνωσης', hu: 'perc olvasás'
};

const {
  langCodes = [],
  keywords = [],
  categories = [],
  maxArticles = 12,
  title,
  subtitle,
  nativeLang = 'en'
} = Astro.props;

const t = getUITranslations(nativeLang);
const displayTitle = title || relatedArticlesLabel[nativeLang] || relatedArticlesLabel.en;

// Get all articles
const allArticles = await getArticlesByNativeLang(nativeLang, { limit: 2000 });

// Filter articles
let filteredArticles = allArticles.filter(article => {
  const articleTargetLang = article.target_lang;

  // If langCodes specified, must match one
  if (langCodes.length > 0 && !langCodes.includes(articleTargetLang)) return false;

  // If keywords specified, title must contain at least one
  if (keywords.length > 0) {
    const titleLower = article.title.toLowerCase();
    const descLower = (article.description || '').toLowerCase();
    const hasKeyword = keywords.some(kw =>
      titleLower.includes(kw.toLowerCase()) || descLower.includes(kw.toLowerCase())
    );
    if (!hasKeyword) return false;
  }

  // If categories specified, must match one
  if (categories.length > 0) {
    const articleCategory = article.category || '';
    if (!categories.includes(articleCategory)) return false;
  }

  return true;
});

// Sort by date (newest first) and limit
filteredArticles = filteredArticles
  .sort((a, b) => new Date(b.date || 0).getTime() - new Date(a.date || 0).getTime())
  .slice(0, maxArticles);

// Get article URL
const getArticleUrl = (article: BlogArticleSummary) => `/learn/${article.native_lang}/${article.target_lang}/${article.slug}/`;

// Truncate helper
const truncate = (str: string, len: number) => {
  if (!str || str.length <= len) return str;
  return str.substring(0, len).trim() + '...';
};

const totalFound = filteredArticles.length;
---

{totalFound > 0 && (
  <section class="py-12 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-bold font-header text-gray-900 mb-2">
          {displayTitle}
        </h2>
        {subtitle && (
          <p class="text-gray-600">{subtitle}</p>
        )}
        <p class="text-sm text-gray-500 mt-2">
          <span class="font-semibold text-accent">{totalFound}</span> {articlesFoundLabel[nativeLang] || articlesFoundLabel.en}
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {filteredArticles.map(article => {
          const langCode = article.target_lang;
          const langData = LANGUAGE_HUB_DATA[langCode];

          return (
            <a
              href={getArticleUrl(article)}
              class="group p-4 bg-gray-50 rounded-xl border border-gray-100 hover:border-accent hover:shadow-md transition-all"
            >
              <div class="flex items-center gap-2 mb-3">
                <span class="text-lg">{langData?.flag || '🌍'}</span>
                <span class="text-xs font-medium text-gray-500 uppercase">{langData?.name || 'Language'}</span>
                {article.category && (
                  <span class="text-xs px-2 py-0.5 bg-gray-200 rounded-full capitalize ml-auto">
                    {article.category}
                  </span>
                )}
              </div>
              <h3 class="font-semibold text-gray-900 group-hover:text-accent transition-colors text-sm leading-tight mb-2 line-clamp-2">
                {article.title}
              </h3>
              <p class="text-xs text-gray-500 line-clamp-2">
                {truncate(article.description || '', 100)}
              </p>
              {article.read_time && (
                <p class="text-xs text-gray-400 mt-2">{article.read_time} {minReadLabel[nativeLang] || minReadLabel.en}</p>
              )}
            </a>
          );
        })}
      </div>
    </div>
  </section>
)}
