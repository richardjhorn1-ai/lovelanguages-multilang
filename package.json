{
  "name": "lovelanguages",
  "version": "1.0.0",
  "description": "Love Languages - Learn your partner's language",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:blog": "cd blog && npm run dev",
    "setup:blog": "npm --prefix blog ci",
    "build": "npm run build:app && npm run build:blog && cp -r dist/* blog/.vercel/output/static/ && mkdir -p .vercel/output && cp -r blog/.vercel/output/* .vercel/output/",
    "build:app": "vite build",
    "build:blog": "cd blog && npm run build",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings 0",
    "typecheck:app": "tsc --noEmit -p tsconfig.app.json",
    "typecheck:api": "tsc --noEmit -p tsconfig.api.json",
    "typecheck:blog": "cd blog && npm exec astro check",
    "test:unit": "vitest run",
    "preview": "vite preview",
    "import-content": "node scripts/import-content.cjs",
    "generate-article": "node --env-file=.env --import=tsx scripts/generate-article.ts",
    "onboarding:inspect": "node --env-file=.env scripts/onboarding/inspect-user.mjs",
    "blog:slug-native:dry-run": "node blog/scripts/promote-slug-native-canonicals.mjs --dry-run",
    "blog:slug-native:apply": "node blog/scripts/promote-slug-native-canonicals.mjs --apply",
    "seo:inventory": "node scripts/seo/generate-url-inventory.mjs",
    "seo:audit": "node scripts/seo/audit-deployed-seo.mjs",
    "seo:validate-routes": "node scripts/seo/validate-route-ownership.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "cap:sync": "VITE_API_BASE_URL=https://www.lovelanguages.io npm run build:app && npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:build:ios": "VITE_API_BASE_URL=https://www.lovelanguages.io npm run build:app && npx cap sync ios && npx cap open ios"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.0.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.0.1",
    "@capacitor/network": "^8.0.0",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.0",
    "@google/genai": "*",
    "@google/generative-ai": "^0.24.1",
    "@mdx-js/react": "^3.1.1",
    "@phosphor-icons/react": "^2.1.10",
    "@revenuecat/purchases-capacitor": "^12.2.0",
    "@stripe/stripe-js": "^8.6.1",
    "@supabase/supabase-js": "^2.39.8",
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.3.1",
    "i18next": "^25.7.4",
    "idb": "^8.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-easy-crop": "^5.5.6",
    "react-i18next": "^16.5.2",
    "react-router-dom": "^6.22.3",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.7.0",
    "stripe": "^20.1.2"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@capacitor/cli": "^8.2.0",
    "@mdx-js/rollup": "^3.1.1",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.24",
    "browserslist": "^4.28.1",
    "caniuse-lite": "^1.0.30001766",
    "dotenv": "^17.2.3",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^15.15.0",
    "jsdom": "^27.4.0",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.26.1",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.16"
  },
  "overrides": {
    "minimatch": "^9.0.7"
  }
}
