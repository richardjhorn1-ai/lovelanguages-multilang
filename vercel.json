{
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=8192"
    }
  },
  "installCommand": "npm ci && npm --prefix blog ci",
  "cleanUrls": false,
  "redirects": [
    {
      "source": "/:path((?!story/).*)",
      "has": [
        {
          "type": "host",
          "value": "story.lovelanguages.io"
        }
      ],
      "destination": "/story/",
      "permanent": false
    },
    {
      "source": "/learn/easiest-languages/",
      "destination": "/learn/",
      "permanent": true
    },
    {
      "source": "/learn/romance-languages/",
      "destination": "/learn/",
      "permanent": true
    },
    {
      "source": "/learn/slavic-languages/",
      "destination": "/learn/",
      "permanent": true
    },
    {
      "source": "/learn/romantic-phrases/",
      "destination": "/learn/",
      "permanent": true
    },
    {
      "source": "/learn/couples-language-learning/",
      "destination": "/learn/en/couples-language-learning/",
      "permanent": true
    },
    {
      "source": "/learn/language/polish/:path*",
      "destination": "/learn/en/pl/",
      "permanent": true
    },
    {
      "source": "/learn/language/spanish/:path*",
      "destination": "/learn/en/es/",
      "permanent": true
    },
    {
      "source": "/learn/language/french/:path*",
      "destination": "/learn/en/fr/",
      "permanent": true
    },
    {
      "source": "/learn/language/german/:path*",
      "destination": "/learn/en/de/",
      "permanent": true
    },
    {
      "source": "/learn/language/italian/:path*",
      "destination": "/learn/en/it/",
      "permanent": true
    },
    {
      "source": "/learn/language/portuguese/:path*",
      "destination": "/learn/en/pt/",
      "permanent": true
    },
    {
      "source": "/learn/language/russian/:path*",
      "destination": "/learn/en/ru/",
      "permanent": true
    },
    {
      "source": "/learn/language/ukrainian/:path*",
      "destination": "/learn/en/uk/",
      "permanent": true
    },
    {
      "source": "/learn/language/czech/:path*",
      "destination": "/learn/en/cs/",
      "permanent": true
    },
    {
      "source": "/learn/language/greek/:path*",
      "destination": "/learn/en/el/",
      "permanent": true
    },
    {
      "source": "/learn/language/dutch/:path*",
      "destination": "/learn/en/nl/",
      "permanent": true
    },
    {
      "source": "/learn/language/swedish/:path*",
      "destination": "/learn/en/sv/",
      "permanent": true
    },
    {
      "source": "/learn/language/norwegian/:path*",
      "destination": "/learn/en/no/",
      "permanent": true
    },
    {
      "source": "/learn/language/danish/:path*",
      "destination": "/learn/en/da/",
      "permanent": true
    },
    {
      "source": "/learn/language/hungarian/:path*",
      "destination": "/learn/en/hu/",
      "permanent": true
    },
    {
      "source": "/learn/language/turkish/:path*",
      "destination": "/learn/en/tr/",
      "permanent": true
    },
    {
      "source": "/learn/language/romanian/:path*",
      "destination": "/learn/en/ro/",
      "permanent": true
    },
    {
      "source": "/learn/polish-pet-names/",
      "destination": "/learn/en/pl/50-polish-terms-of-endearment-complete-guide-to-polish-pet-names/",
      "permanent": true
    },
    {
      "source": "/learn/uk/100-common-ukrainian-words/",
      "destination": "/learn/en/uk/100-common-ukrainian-words/",
      "permanent": true
    },
    {
      "source": "/learn/tr/100-common-turkish-words/",
      "destination": "/learn/en/tr/100-common-turkish-words/",
      "permanent": true
    },
    {
      "source": "/learn/pl/100-most-common-polish-words-essential-vocabulary-for-couples-learning-together/",
      "destination": "/learn/en/pl/100-most-common-polish-words-essential-vocabulary-for-couples-learning-together/",
      "permanent": true
    },
    {
      "source": "/learn/pl/50-polish-terms-of-endearment-complete-guide-to-polish-pet-names/",
      "destination": "/learn/en/pl/50-polish-terms-of-endearment-complete-guide-to-polish-pet-names/",
      "permanent": true
    },
    {
      "source": "/learn/pl/7-polish-pronunciation-mistakes-english-speakers-make-and-how-to-fix-them/",
      "destination": "/learn/en/pl/7-polish-pronunciation-mistakes-english-speakers-make-and-how-to-fix-them/",
      "permanent": true
    },
    {
      "source": "/learn/cs/100-common-czech-words/",
      "destination": "/learn/en/cs/100-common-czech-words/",
      "permanent": true
    },
    {
      "source": "/learn/da/100-common-danish-words/",
      "destination": "/learn/en/da/100-common-danish-words/",
      "permanent": true
    },
    {
      "source": "/learn/el/100-common-greek-words/",
      "destination": "/learn/en/el/100-common-greek-words/",
      "permanent": true
    },
    {
      "source": "/learn/hu/100-common-hungarian-words/",
      "destination": "/learn/en/hu/100-common-hungarian-words/",
      "permanent": true
    },
    {
      "source": "/learn/nl/100-common-dutch-words/",
      "destination": "/learn/en/nl/100-common-dutch-words/",
      "permanent": true
    },
    {
      "source": "/learn/no/100-common-norwegian-words/",
      "destination": "/learn/en/no/100-common-norwegian-words/",
      "permanent": true
    },
    {
      "source": "/learn/ro/100-common-romanian-words/",
      "destination": "/learn/en/ro/100-common-romanian-words/",
      "permanent": true
    },
    {
      "source": "/learn/sv/100-common-swedish-words/",
      "destination": "/learn/en/sv/100-common-swedish-words/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/privacy/",
      "destination": "/privacy/index.html"
    },
    {
      "source": "/terms/",
      "destination": "/terms/index.html"
    },
    {
      "source": "/compare/",
      "destination": "/compare/index.html"
    },
    {
      "source": "/compare/:lang/",
      "destination": "/compare/:lang/index.html"
    },
    {
      "source": "/compare/:lang/:slug/",
      "destination": "/compare/:lang/:slug/index.html"
    },
    {
      "source": "/((?!\\.well-known|apple-app-site-association|learn|compare|tools|dictionary|support|api|_vercel|assets|sitemap|story).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    },
    {
      "source": "/apple-app-site-association",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    },
    {
      "source": "/learn/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/compare/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://vercel.live https://cdn.tailwindcss.com https://www.googletagmanager.com https://us.i.posthog.com https://us-assets.i.posthog.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://generativelanguage.googleapis.com wss://generativelanguage.googleapis.com https://api.stripe.com https://api.openai.com wss://api.openai.com https://www.google-analytics.com https://*.google-analytics.com https://*.googletagmanager.com https://fonts.googleapis.com https://fonts.gstatic.com https://us.i.posthog.com https://us-assets.i.posthog.com; frame-src https://js.stripe.com https://checkout.stripe.com https://vercel.live; media-src 'self' blob: https://*.supabase.co; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), microphone=(self), geolocation=(), payment=(self)"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        }
      ]
    }
  ]
}
